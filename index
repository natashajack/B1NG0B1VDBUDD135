  .roombar .code {
    font-family:'Courier New',monospace; font-weight:700; font-size:22px;
    letter-spacing: 0.3em; color: var(--gold-tint);
  }
  .roombar .sep { width:1px; height:30px; background: rgba(255,255,255,0.18); }
  .roombar .meta { font-size:12px; line-height:1.4; opacity:.85; }
  .roombar .meta b { color:#fff; }
  .roombar .spacer { flex:1; }
  .copybtn {
    font: inherit; font-size:12px; cursor:pointer; border:none;
    background: rgba(255,255,255,0.12); color:#fff; padding:7px 12px; border-radius:3px;
  }
  .copybtn:hover { background: rgba(255,255,255,0.22); }
  /* ---- Bingo board ---- */
  .board-frame {
    background: var(--teal-deep);
    padding: 10px;
    border-radius: 6px;
    box-shadow: 0 10px 30px var(--shadow);
  }
  .board {
    display:grid; grid-template-columns: repeat(5,1fr); gap: 6px;
  }
  .cell {
    position: relative;
    aspect-ratio: 1 / 1;
    background: var(--teal-tint);
    border: none;
    border-radius: 3px;
    color: var(--teal-deep);
    font-weight: 600;
    font-size: clamp(9px, 2.1vw, 13px);
    line-height: 1.12;
    padding: 4px;
    display:flex; align-items:center; justify-content:center; text-align:center;
    cursor: pointer; overflow:hidden;
    transition: transform .08s, background .15s;
    -webkit-tap-highlight-color: transparent;
  }
  .cell:hover { background: #c3dade; }
  .cell:active { transform: scale(0.96); }
  .cell.free {
    background: var(--free); color: var(--gold); font-weight:800;
    cursor: default;
  }
  .cell.marked {
    background: var(--teal);
    color: #fff;
  }
  .cell.marked::after {
    content: "";
    position:absolute; inset: 4px;
    border: 2px solid rgba(255,255,255,0.55);
    border-radius: 50%;
  }
  .cell.free.marked::after { border-color: var(--gold); }
  .cell.win { animation: pop .4s ease; box-shadow: inset 0 0 0 3px var(--gold); }
  @keyframes pop { 0%{transform:scale(1);} 50%{transform:scale(1.08);} 100%{transform:scale(1);} }
  .cell-txt { position:relative; z-index:1; }
  /* ---- Win banner ---- */
  .banner {
    background: var(--stamp); color: #fff; text-align:center;
    padding: 16px; border-radius: 5px; margin-bottom: 16px;
    font-weight: 800; letter-spacing: 0.06em; font-size: 18px;
    border: 2px dashed rgba(255,255,255,0.5);
  }
  .banner small { display:block; font-weight:500; letter-spacing:0.02em; font-size:13px; opacity:.9; margin-top:4px; }
  /* ---- Players / activity ---- */
  .players { display:flex; flex-wrap:wrap; gap:8px; margin-top:4px; }
  .pchip {
    font-size:12px; background:var(--paper); border:1px solid var(--line);
    padding:6px 12px; border-radius:999px; display:flex; align-items:center; gap:7px;
  }
  .pchip .dot { width:8px; height:8px; border-radius:50%; background:var(--teal); }
  .pchip.bingo { background: var(--gold-tint); border-color: var(--gold); font-weight:700; }
  .pchip.bingo .dot { background: var(--stamp); }
  .feed { margin-top:8px; max-height: 220px; overflow:auto; }
  .feed-item { font-size:13px; padding:8px 0; border-bottom:1px dashed var(--line); display:flex; gap:10px; }
  .feed-item .ts { font-family:'Courier New',monospace; color:#a59c87; font-size:11px; white-space:nowrap; }
  .feed-item b { color: var(--teal-deep); }
  .feed-empty { font-size:13px; color:#9a917d; padding: 12px 0; }
  .footnote { text-align:center; font-size:11px; color:#a59c87; margin-top:28px; letter-spacing:0.04em; }
  .err { color: var(--stamp); font-size:13px; margin-top:8px; }
  .toast {
    position: fixed; bottom: 24px; left:50%; transform:translateX(-50%);
    background: var(--ink); color:#fff; padding:12px 20px; border-radius:5px;
    font-size:14px; z-index:50; box-shadow:0 8px 24px var(--shadow);
    animation: rise .3s ease;
  }
  @keyframes rise { from{opacity:0; transform:translate(-50%,12px);} to{opacity:1;transform:translate(-50%,0);} }
  .small-link { background:none; border:none; color:var(--teal); font:inherit; font-size:13px; cursor:pointer; text-decoration:underline; padding:0; }
  .modal-bg {
    position: fixed; inset: 0; z-index: 60;
    background: rgba(26,46,53,0.55);
    display:flex; align-items:flex-start; justify-content:center;
    padding: 40px 16px; overflow:auto;
  }
  .modal {
    background:#fff; border:1px solid var(--line); border-radius:6px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.3);
    padding: 24px; width: 100%; max-width: 560px;
    border-top: 4px solid var(--gold);
  }
  .modal h2 {
    font-size: 13px; text-transform: uppercase; letter-spacing: 0.16em;
    color: var(--teal); margin-bottom: 4px; font-family:'Courier New',monospace;
  }
  .modal .hint { font-size:13px; color:#6b6555; margin-bottom:16px; line-height:1.5; }
  code.inline { background:var(--teal-tint); padding:1px 6px; border-radius:3px; font-family:'Courier New',monospace; font-size:12px; }
  @media (max-width:480px){
    .roombar .meta { display:none; }
    .panel { padding:16px; }
  }
  @media (prefers-reduced-motion: reduce){
    *, .cell.win { animation:none !important; transition:none !important; }
  }
</style>
