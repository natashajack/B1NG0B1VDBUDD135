<body>
<div id="root"></div>
 
<script type="text/babel">
const { useState, useEffect, useRef, useCallback } = React;
 
/* =====================================================================
   FIREBASE CONFIG  —  PASTE YOUR VALUES HERE
   ---------------------------------------------------------------------
   In the Firebase console: Project settings (gear icon) > "Your apps" >
   register a Web app > copy the firebaseConfig object it shows you.
   IMPORTANT: you must have created a *Realtime Database* (not Firestore)
   so that "databaseURL" exists. If databaseURL is missing from the
   snippet, create the Realtime Database first, then re-copy the config.
   It's safe for these values to be public — that's how Firebase web works.
   Access is controlled by the database security rules, not by hiding keys.
   ===================================================================== */
const firebaseConfig = {
  apiKey:            "AIzaSyDbKRshWhEnxbdMpLLyzGuZVA2OKAH8XwA",
  authDomain:        "buzzword-bingo-ff4ca.firebaseapp.com",
  databaseURL:       "https://buzzword-bingo-ff4ca-default-rtdb.firebaseio.com",
  projectId:         "buzzword-bingo-ff4ca",
  storageBucket:     "buzzword-bingo-ff4ca.firebasestorage.app",
  messagingSenderId: "735564029543",
  appId:             "1:735564029543:web:da92a291bf5061861e7ec2"
};
 
// Has the config actually been filled in yet?
const NEEDS_CONFIG = Object.values(firebaseConfig)
  .some(v => typeof v === "string" && v.indexOf("PASTE_") === 0);
 
let db = null;
if (!NEEDS_CONFIG) {
  firebase.initializeApp(firebaseConfig);
  db = firebase.database();
}
 
/* ----------------------- storage layer (Firebase RTDB) -----------------------
   This replaces the old window.storage get/set calls. Each room lives at
   /rooms/<CODE>. We use targeted writes (per-player, per-field) and a feed
   that is push()-ed rather than rewritten wholesale, so two people acting at
   the same moment don't overwrite each other's changes. */
function roomRef(code){ return db.ref('rooms/' + code); }
 
async function loadRoom(code){
  try {
    const snap = await roomRef(code).get();
    return snap.exists() ? snap.val() : null;
  } catch(e){ return null; }
}
async function saveRoom(code, data){
  try { await roomRef(code).set(data); return true; }
  catch(e){ return false; }
}
// Append one activity-feed entry. ts is used purely for ordering.
function pushFeed(code, who, msg){
  return roomRef(code).child('feed').push({ t: now(), who: who, msg: msg, ts: Date.now() });
}
 
/* ----------------------- utilities ----------------------- */
const CODE_CHARS = "ABCDEFGHJKLMNPQRSTUVWXYZ23456789";
function makeCode(){ let s=""; for(let i=0;i<4;i++) s+=CODE_CHARS[Math.floor(Math.random()*CODE_CHARS.length)]; return s; }
function uid(){ return Math.random().toString(36).slice(2,10); }
function shuffle(a){ const x=a.slice(); for(let i=x.length-1;i>0;i--){ const j=Math.floor(Math.random()*(i+1)); [x[i],x[j]]=[x[j],x[i]]; } return x; }
function now(){ return new Date().toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'}); }
 
// RTDB returns arrays as arrays when keys are contiguous, but normalize anyway.
function asList(v){ return Array.isArray(v) ? v : (v ? Object.values(v) : []); }
// Feed is stored as a push()-keyed object; render newest-first, capped at 40.
function feedArray(room){
  if(!room || !room.feed) return [];
  return Object.values(room.feed).sort((a,b)=>(b.ts||0)-(a.ts||0)).slice(0,40);
}
 
const DEFAULT_PHRASES = [
`"Let's take this offline"
"Circle back"
"Synergy"
"Move the needle"
"Low-hanging fruit"
"Touch base"
"Ping me"
"Deep dive"
"Bandwidth"
"Boil the ocean"
"Drink from the firehose"
"At the end of the day"
"Open the kimono"
"Run it up the flagpole"
"Think outside the box"
"Going forward"
"Per my last email"
"Quick question..."
"Let's parking-lot that"
"Double-click on that"
"Net-net"
"Hard stop at the top of the hour"
"You're on mute"
"Can everyone see my screen?"
"Sorry, you go first"
"Let's take it from the top"
"Action items"
"Aligning stakeholders"
"Make it a priority"
"Loop them in"
"Reach out"
"It is what it is"
"Let's not reinvent the wheel"
"Wearing many hats"
"Give 110%"`
];
 
// Win detection (5x5, center = index 12 free)
function lines(){
  const L=[];
  for(let r=0;r<5;r++) L.push([0,1,2,3,4].map(c=>r*5+c));
  for(let c=0;c<5;c++) L.push([0,1,2,3,4].map(r=>r*5+c));
  L.push([0,6,12,18,24]); L.push([4,8,12,16,20]);
  return L;
}
const LINES = lines();
function checkWin(marked){
  for(const ln of LINES){ if(ln.every(i=>marked[i])) return ln; }
  return null;
}
 
/* ----------------------- Setup notice (shown until config pasted) ----------------------- */
function SetupNotice(){
  return (
    <div className="wrap">
      <div className="memo-head">
        <div className="eyebrow">Interoffice Memo · Re: Setup</div>
        <h1 className="memo-title">Almost <em>there</em></h1>
        <p className="memo-sub">The game is wired up for Firebase, it just needs your project's keys before rooms can sync.</p>
      </div>
      <div className="panel">
        <h2>One step left</h2>
        <p className="hint">Open <code className="inline">index.html</code> and paste your Firebase web-app config into the
          <code className="inline">firebaseConfig</code> block near the top of the script. Make sure you've created a
          <b> Realtime Database</b> so a <code className="inline">databaseURL</code> exists. Save, refresh, and this notice disappears.</p>
        <p className="hint" style={{marginBottom:0}}>Full walkthrough is in <code className="inline">SETUP.md</code> next to this file.</p>
      </div>
      <div className="footnote">These keys are meant to ship in the page — Firebase security rules are what protect the data.</div>
    </div>
  );
}
 
/* ----------------------- App ----------------------- */
function App(){
  const [view, setView] = useState('lobby'); // lobby | game
  const [tab, setTab] = useState('join');
  const [name, setName] = useState('');
  const [joinCode, setJoinCode] = useState('');
  const [phrasesText, setPhrasesText] = useState(DEFAULT_PHRASES[0]);
  const [roomTitle, setRoomTitle] = useState('Monday All-Hands Bingo');
  const [err, setErr] = useState('');
  const [code, setCode] = useState(null);
  const [meId] = useState(uid());
  const [room, setRoom] = useState(null);
  const [myMarks, setMyMarks] = useState({}); // index -> true
  const [myCells, setMyCells] = useState(null); // array of 25 strings
  const [didWin, setDidWin] = useState(false);
  const [winLine, setWinLine] = useState(null);
  const [toast, setToast] = useState('');
  const [showEdit, setShowEdit] = useState(false);
  const [editText, setEditText] = useState('');
  const [editTitle, setEditTitle] = useState('');
  const [editErr, setEditErr] = useState('');
  const seenRound = useRef(0);
  const roomRefLive = useRef(null);
  const showToast = (m) => { setToast(m); setTimeout(()=>setToast(''), 1800); };
 
  /* ---- build a personal card from room phrases ---- */
  function buildCard(phrases){
    const pool = asList(phrases).filter(p=>p && p.trim().length);
    const picked = shuffle(pool).slice(0,24);
    const cells = [];
    for(let i=0;i<25;i++){
      if(i===12) cells.push("FREE\nSPACE");
      else cells.push(picked[i<12?i:i-1] || "—");
    }
    return cells;
  }
 
  /* ---- create room (host) ---- */
  async function hostCreate(){
    setErr('');
    if(!name.trim()){ setErr('Add your name first.'); return; }
    const phrases = phrasesText.split('\n').map(s=>s.trim().replace(/^["']|["']$/g,'')).filter(Boolean);
    if(phrases.length < 24){ setErr(`Need at least 24 phrases — you have ${phrases.length}. Add ${24-phrases.length} more.`); return; }
    let c = makeCode();
    // avoid collision
    for(let t=0;t<5;t++){ const ex = await loadRoom(c); if(!ex) break; c = makeCode(); }
    const data = {
      code: c, title: roomTitle.trim() || 'Buzzword Bingo',
      phrases, hostId: meId, createdAt: Date.now(), round: 1,
      players: { [meId]: { name: name.trim(), joined: Date.now(), bingoAt: null } }
    };
    const ok = await saveRoom(c, data);
    if(!ok){ setErr('Could not reach the database — check your Firebase config and rules.'); return; }
    await pushFeed(c, name.trim(), 'started the meeting 📋');
    setCode(c); setRoom(data);
    seenRound.current = 1;
    setMyCells(buildCard(phrases)); setMyMarks({12:true});
    setView('game');
  }
 
  /* ---- join room ---- */
  async function doJoin(){
    setErr('');
    if(!name.trim()){ setErr('Add your name first.'); return; }
    const c = joinCode.trim().toUpperCase();
    if(c.length !== 4){ setErr('Room codes are 4 characters.'); return; }
    const data = await loadRoom(c);
    if(!data){ setErr('No room with that code. Check with your host.'); return; }
    // targeted write: only my own player record, so I don't clobber anyone else
    await roomRef(c).child('players/'+meId).set({ name: name.trim(), joined: Date.now(), bingoAt: null });
    await pushFeed(c, name.trim(), 'joined the call 👋');
    setCode(c); setRoom(data);
    seenRound.current = data.round || 1;
    setMyCells(buildCard(data.phrases)); setMyMarks({12:true});
    setView('game');
  }
 
  /* ---- live updates via Realtime Database listener (replaces polling) ---- */
  useEffect(()=>{
    if(view!=='game' || !code) return;
    const ref = roomRef(code);
    const cb = ref.on('value', (snap)=>{
      const data = snap.val();
      if(!data) return; // room gone
      setRoom(data);
      const r = data.round || 1;
      if(r > seenRound.current){
        seenRound.current = r;
        setMyCells(buildCard(data.phrases));
        setMyMarks({12:true}); setDidWin(false); setWinLine(null);
        showToast('Host started a new round — fresh card dealt');
      }
    });
    roomRefLive.current = { ref, cb };
    return ()=>{ ref.off('value', cb); };
  }, [view, code]);
 
  /* ---- toggle a cell ---- */
  function toggleCell(i){
    if(i===12) return;
    setMyMarks(prev=>{
      const next = {...prev};
      if(next[i]) delete next[i]; else next[i]=true;
      return next;
    });
  }
 
  /* ---- detect win locally, announce to room ---- */
  useEffect(()=>{
    if(!myCells) return;
    const arr = myCells.map((_,i)=> !!myMarks[i] || i===12);
    const ln = checkWin(arr);
    if(ln && !didWin){
      setDidWin(true); setWinLine(ln);
      announceBingo();
    }
    if(!ln && didWin){ setDidWin(false); setWinLine(null); }
  }, [myMarks, myCells]);
 
  async function announceBingo(){
    if(!code) return;
    // Transaction: set bingoAt only if it isn't already set. Returning undefined
    // aborts, so committed===true means *we* recorded the bingo (no double-posts).
    const ref = roomRef(code).child('players/'+meId+'/bingoAt');
    let res;
    try { res = await ref.transaction(cur => cur ? undefined : Date.now()); }
    catch(e){ return; }
    if(!res || !res.committed) return;
    // compute placing from a fresh read
    const snap = await roomRef(code).child('players').get();
    const players = snap.val() || {};
    const place = Object.values(players).filter(p=>p && p.bingoAt).length;
    const myName = (players[meId] && players[meId].name) || name.trim() || 'Someone';
    await pushFeed(code, myName, place===1 ? 'GOT BINGO FIRST 🏆' : `got bingo (#${place})`);
  }
 
  async function leave(){
    if(roomRefLive.current){ roomRefLive.current.ref.off('value', roomRefLive.current.cb); }
    const nm = (room && room.players && room.players[meId] && room.players[meId].name) || name.trim() || 'Someone';
    if(code){
      await roomRef(code).child('players/'+meId).remove();
      await pushFeed(code, nm, 'left the meeting 🚪');
    }
    setView('lobby'); setCode(null); setRoom(null); setMyCells(null); setMyMarks({}); setDidWin(false);
  }
 
  async function newCard(){
    if(!room) return;
    setMyCells(buildCard(room.phrases)); setMyMarks({12:true}); setDidWin(false); setWinLine(null);
    // clear my bingoAt so a fresh card can win again
    if(code){ await roomRef(code).child('players/'+meId+'/bingoAt').set(null); }
    showToast('Fresh card dealt');
  }
 
  function openEditor(){
    if(!room) return;
    setEditText(asList(room.phrases).join('\n'));
    setEditTitle(room.title);
    setEditErr('');
    setShowEdit(true);
  }
 
  async function saveNewBoard(){
    setEditErr('');
    const phrases = editText.split('\n').map(s=>s.trim().replace(/^["']|["']$/g,'')).filter(Boolean);
    if(phrases.length < 24){ setEditErr(`Need at least 24 phrases — you have ${phrases.length}.`); return; }
    if(!code || !room){ setEditErr('Lost the room. Try rejoining.'); return; }
    const round = (room.round || 1) + 1;
    // one atomic multi-path update: new board + reset every player's bingo for the round
    const updates = { phrases: phrases, title: editTitle.trim() || room.title, round: round };
    Object.keys(room.players || {}).forEach(id=>{ updates['players/'+id+'/bingoAt'] = null; });
    await roomRef(code).update(updates);
    const myName = (room.players[meId] && room.players[meId].name) || 'Host';
    await pushFeed(code, myName, `revised the board — round ${round} 🔄`);
    // re-deal my own card immediately (listener will sync everyone else)
    seenRound.current = round;
    setMyCells(buildCard(phrases)); setMyMarks({12:true}); setDidWin(false); setWinLine(null);
    setShowEdit(false);
    showToast('New board sent to everyone');
  }
 
  function copyCode(){
    const t = code;
    if(navigator.clipboard){ navigator.clipboard.writeText(t).then(()=>showToast('Room code copied')); }
    else showToast('Code: '+t);
  }
 
  /* =================== RENDER =================== */
  if(view==='lobby'){
    return (
      <div className="wrap">
        <div className="memo-head">
          <div className="eyebrow">Interoffice Memo · Re: Morale</div>
          <h1 className="memo-title">Buzzword <em>Bingo</em></h1>
          <p className="memo-sub">A live game for the next all-hands, stand-up, or town hall. Make a card of the phrases your coworkers can't stop saying, share the room code, and quietly compete while looking very engaged.</p>
        </div>
        <div className="tabs">
          <div className={"tab"+(tab==='join'?' active':'')} onClick={()=>{setTab('join');setErr('')}}>Join a Room</div>
          <div className={"tab"+(tab==='host'?' active':'')} onClick={()=>{setTab('host');setErr('')}}>Host a Room</div>
        </div>
        <div className="panel">
          <label className="field">Your name (or alias)</label>
          <input className="text" placeholder="e.g. Definitely Working" value={name} onChange={e=>setName(e.target.value)} maxLength={24}/>
        </div>
        {tab==='join' ? (
          <div className="panel">
            <h2>Have a code?</h2>
            <p className="hint">Your host shared a 4-letter room code. Drop it in and you'll get your own randomized card.</p>
            <label className="field">Room code</label>
            <input className="text mono" style={{textTransform:'uppercase',letterSpacing:'0.3em',fontWeight:700,fontSize:20}} placeholder="ABCD" value={joinCode} onChange={e=>setJoinCode(e.target.value.toUpperCase().slice(0,4))} maxLength={4}/>
            {err && <div className="err">{err}</div>}
            <div style={{marginTop:16}}><button className="btn" onClick={doJoin}>Join the meeting →</button></div>
          </div>
        ) : (
          <div className="panel">
            <h2>Set the agenda</h2>
            <p className="hint">List the phrases, buzzwords, and recurring bits — one per line. Everyone gets a unique card drawn from this list, so the more you add the better. Minimum 24.</p>
            <label className="field">Game title</label>
            <input className="text" value={roomTitle} onChange={e=>setRoomTitle(e.target.value)} maxLength={48} style={{marginBottom:16}}/>
            <label className="field">Phrases · one per line</label>
            <textarea className="text" value={phrasesText} onChange={e=>setPhrasesText(e.target.value)} spellCheck={false}/>
            <div style={{fontSize:12,color:'#9a917d',marginTop:6}}>{phrasesText.split('\n').filter(s=>s.trim()).length} lines</div>
            {err && <div className="err">{err}</div>}
            <div style={{marginTop:16,display:'flex',gap:10,flexWrap:'wrap'}}>
              <button className="btn gold" onClick={hostCreate}>Open the room →</button>
              <button className="btn ghost small" onClick={()=>setPhrasesText(DEFAULT_PHRASES[0])}>Reset to classics</button>
            </div>
          </div>
        )}
        <div className="footnote">Up to 15 players · cards update live · keep this tab open during the meeting</div>
      </div>
    );
  }
 
  /* ---- GAME VIEW ---- */
  const players = room ? Object.entries(room.players || {}) : [];
  const winners = players.filter(([,p])=>p.bingoAt).sort((a,b)=>a[1].bingoAt-b[1].bingoAt);
  const feed = feedArray(room);
  return (
    <div className="wrap">
      <div className="memo-head" style={{marginBottom:16}}>
        <div className="eyebrow">Now in session</div>
        <h1 className="memo-title" style={{fontSize:'clamp(24px,5vw,34px)'}}>{room?.title || 'Buzzword Bingo'}</h1>
      </div>
      <div className="roombar">
        <div>
          <div style={{fontSize:10,letterSpacing:'0.25em',opacity:.7,textTransform:'uppercase'}}>Room</div>
          <div className="code">{code}</div>
        </div>
        <div className="sep"></div>
        <div className="meta"><b>{players.length}</b> / 15 present<br/><b>{winners.length}</b> bingo{winners.length!==1?'s':''} so far</div>
        <div className="spacer"></div>
        <button className="copybtn" onClick={copyCode}>Copy code</button>
        <button className="copybtn" onClick={leave}>Leave</button>
      </div>
      {didWin && (
        <div className="banner">
          BINGO — looking very engaged 🏆
          <small>{winners.length>1 ? `You're #${winners.findIndex(([id])=>id===meId)+1} to call it.` : 'First one to call it. Act surprised.'}</small>
        </div>
      )}
      <div className="board-frame">
        <div className="board">
          {myCells && myCells.map((txt,i)=>{
            const marked = !!myMarks[i] || i===12;
            const free = i===12;
            const isWin = winLine && winLine.includes(i);
            return (
              <button key={i}
                className={"cell"+(free?' free':'')+(marked?' marked':'')+(isWin?' win':'')}
                onClick={()=>toggleCell(i)}
                aria-pressed={marked}
                title={txt.replace('\n',' ')}>
                <span className="cell-txt">{txt.split('\n').map((l,k)=><div key={k}>{l}</div>)}</span>
              </button>
            );
          })}
        </div>
      </div>
      <div style={{display:'flex',gap:10,marginTop:14,flexWrap:'wrap'}}>
        <button className="btn ghost small" onClick={newCard}>Deal me a new card</button>
        {room && room.hostId===meId && <button className="btn gold small" onClick={openEditor}>Edit the board</button>}
        <div style={{flex:1}}></div>
        <span style={{fontSize:12,color:'#9a917d',alignSelf:'center'}}>Tap a square when you hear it</span>
      </div>
      <div className="panel" style={{marginTop:18}}>
        <h2>In the room</h2>
        <div className="players">
          {players.length===0 && <span style={{fontSize:13,color:'#9a917d'}}>Just you so far.</span>}
          {players.map(([id,p])=>(
            <span key={id} className={"pchip"+(p.bingoAt?' bingo':'')}>
              <span className="dot"></span>{p.name}{id===meId?' (you)':''}{p.bingoAt?' · BINGO':''}
            </span>
          ))}
        </div>
      </div>
      <div className="panel">
        <h2>Meeting minutes</h2>
        <div className="feed">
          {feed.length===0 && <div className="feed-empty">Nothing's happened yet. Suspiciously quiet.</div>}
          {feed.map((f,i)=>(
            <div key={i} className="feed-item">
              <span className="ts">{f.t}</span>
              <span><b>{f.who}</b> {f.msg}</span>
            </div>
          ))}
        </div>
      </div>
      <div className="footnote">Live via Firebase · share code <b>{code}</b> to add players</div>
      {showEdit && (
        <div className="modal-bg" onClick={(e)=>{ if(e.target.className==='modal-bg') setShowEdit(false); }}>
          <div className="modal">
            <h2>Revise the board</h2>
            <p className="hint">Rewrite the phrases and everyone gets re-dealt a fresh card the moment you save. Bingo counts reset for the new round. One phrase per line, minimum 24.</p>
            <label className="field">Game title</label>
            <input className="text" value={editTitle} onChange={e=>setEditTitle(e.target.value)} maxLength={48} style={{marginBottom:16}}/>
            <label className="field">Phrases · one per line</label>
            <textarea className="text" value={editText} onChange={e=>setEditText(e.target.value)} spellCheck={false}/>
            <div style={{fontSize:12,color:'#9a917d',marginTop:6}}>{editText.split('\n').filter(s=>s.trim()).length} lines</div>
            {editErr && <div className="err">{editErr}</div>}
            <div style={{marginTop:16,display:'flex',gap:10,flexWrap:'wrap'}}>
              <button className="btn gold" onClick={saveNewBoard}>Send new board to everyone →</button>
              <button className="btn ghost small" onClick={()=>setShowEdit(false)}>Cancel</button>
            </div>
          </div>
        </div>
      )}
      {toast && <div className="toast">{toast}</div>}
    </div>
  );
}
 
ReactDOM.createRoot(document.getElementById('root')).render(
  NEEDS_CONFIG ? <SetupNotice/> : <App/>
);
</script>
</body>
</html>
 
