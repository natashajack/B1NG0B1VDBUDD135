<script type="text/babel">
const { useState, useEffect, useRef, useCallback } = React;
/* ----------------------- storage helpers ----------------------- */
const SHARED = true;
async function loadRoom(code){
  try { const r = await window.storage.get('room:'+code, SHARED); return r ? JSON.parse(r.value) : null; }
  catch(e){ return null; }
}
async function saveRoom(code, data){
  try { await window.storage.set('room:'+code, JSON.stringify(data), SHARED); return true; }
  catch(e){ return false; }
}
/* ----------------------- utilities ----------------------- */
const CODE_CHARS = "ABCDEFGHJKLMNPQRSTUVWXYZ23456789";
function makeCode(){ let s=""; for(let i=0;i<4;i++) s+=CODE_CHARS[Math.floor(Math.random()*CODE_CHARS.length)]; return s; }
function uid(){ return Math.random().toString(36).slice(2,10); }
function shuffle(a){ const x=a.slice(); for(let i=x.length-1;i>0;i--){ const j=Math.floor(Math.random()*(i+1)); [x[i],x[j]]=[x[j],x[i]]; } return x; }
function now(){ return new Date().toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'}); }
const DEFAULT_PHRASES = [
"Let's take this offline"
"Circle back"
"Synergy"
"Move the needle"
"Low-hanging fruit"
"Touch base"
"Ping me"
"Deep dive"
"Bandwidth"
"Boil the ocean"
"Drink from the firehose"
"At the end of the day"
"Open the kimono"
"Run it up the flagpole"
"Think outside the box"
"Going forward"
"Per my last email"
"Quick question..."
"Let's parking-lot that"
"Double-click on that"
"Net-net"
"Hard stop at the top of the hour"
"You're on mute"
"Can everyone see my screen?"
"Sorry, you go first"
"Let's take it from the top"
"Action items"
"Aligning stakeholders"
"Make it a priority"
"Loop them in"
"Reach out"
"It is what it is"
"Let's not reinvent the wheel"
"Wearing many hats"
"Give 110%"
];
// Win detection (5x5, center = index 12 free)
function lines(){
  const L=[];
  for(let r=0;r<5;r++) L.push([0,1,2,3,4].map(c=>r*5+c));
  for(let c=0;c<5;c++) L.push([0,1,2,3,4].map(r=>r*5+c));
  L.push([0,6,12,18,24]); L.push([4,8,12,16,20]);
  return L;
}
const LINES = lines();
function checkWin(marked){
  for(const ln of LINES){ if(ln.every(i=>marked[i])) return ln; }
  return null;
}
/* ----------------------- App ----------------------- */
function App(){
  const [view, setView] = useState('lobby'); // lobby | game
  const [tab, setTab] = useState('join');
  const [name, setName] = useState('');
  const [joinCode, setJoinCode] = useState('');
  const [phrasesText, setPhrasesText] = useState(DEFAULT_PHRASES[0]);
  const [roomTitle, setRoomTitle] = useState('Monday All-Hands Bingo');
  const [err, setErr] = useState('');
  const [code, setCode] = useState(null);
  const [meId] = useState(uid());
  const [room, setRoom] = useState(null);
  const [myMarks, setMyMarks] = useState({}); // index -> true
  const [myCells, setMyCells] = useState(null); // array of 25 strings
  const [didWin, setDidWin] = useState(false);
  const [winLine, setWinLine] = useState(null);
  const [toast, setToast] = useState('');
  const [showEdit, setShowEdit] = useState(false);
  const [editText, setEditText] = useState('');
  const [editTitle, setEditTitle] = useState('');
  const [editErr, setEditErr] = useState('');
  const seenRound = useRef(0);
  const pollRef = useRef(null);
  const showToast = (m) => { setToast(m); setTimeout(()=>setToast(''), 1800); };
  /* ---- build a personal card from room phrases ---- */
  function buildCard(phrases){
    const pool = phrases.filter(p=>p.trim().length);
    const picked = shuffle(pool).slice(0,24);
    const cells = [];
    for(let i=0;i<25;i++){
      if(i===12) cells.push("FREE\nSPACE");
      else cells.push(picked[i<12?i:i-1] || "—");
    }
    return cells;
  }
  /* ---- create room (host) ---- */
  async function hostCreate(){
    setErr('');
    if(!name.trim()){ setErr('Add your name first.'); return; }
    const phrases = phrasesText.split('\n').map(s=>s.trim().replace(/^["']|["']$/g,'')).filter(Boolean);
    if(phrases.length < 24){ setErr(Need at least 24 phrases — you have ${phrases.length}. Add ${24-phrases.length} more.); return; }
    let c = makeCode();
    // avoid collision
    for(let t=0;t<5;t++){ const ex = await loadRoom(c); if(!ex) break; c = makeCode(); }
    const data = {
      code: c, title: roomTitle.trim() || 'Buzzword Bingo',
      phrases, hostId: meId, createdAt: Date.now(), round: 1,
      players: { [meId]: { name: name.trim(), joined: Date.now(), bingoAt: null } },
      feed: [{ t: now(), who: name.trim(), msg: 'started the meeting 📋' }]
    };
    await saveRoom(c, data);
    setCode(c); setRoom(data);
    seenRound.current = 1;
    setMyCells(buildCard(phrases)); setMyMarks({12:true});
    setView('game');
  }
  /* ---- join room ---- */
  async function doJoin(){
    setErr('');
    if(!name.trim()){ setErr('Add your name first.'); return; }
    const c = joinCode.trim().toUpperCase();
    if(c.length !== 4){ setErr('Room codes are 4 characters.'); return; }
    const data = await loadRoom(c);
    if(!data){ setErr('No room with that code. Check with your host.'); return; }
    data.players[meId] = { name: name.trim(), joined: Date.now(), bingoAt: null };
    data.feed = [{ t: now(), who: name.trim(), msg: 'joined the call 👋' }, ...(data.feed||[])].slice(0,40);
    await saveRoom(c, data);
    setCode(c); setRoom(data);
    seenRound.current = data.round || 1;
    setMyCells(buildCard(data.phrases)); setMyMarks({12:true});
    setView('game');
  }
  /* ---- polling for live updates ---- */
  useEffect(()=>{
    if(view!=='game' || !code) return;
    const tick = async ()=>{
      const data = await loadRoom(code);
      if(data){
        setRoom(data);
        const r = data.round || 1;
        if(r > seenRound.current){
          seenRound.current = r;
          setMyCells(buildCard(data.phrases));
          setMyMarks({12:true}); setDidWin(false); setWinLine(null);
          showToast('Host started a new round — fresh card dealt');
        }
      }
    };
    tick();
    pollRef.current = setInterval(tick, 2500);
    return ()=> clearInterval(pollRef.current);
  }, [view, code]);
  /* ---- toggle a cell ---- */
  function toggleCell(i){
    if(i===12) return;
    setMyMarks(prev=>{
      const next = {...prev};
      if(next[i]) delete next[i]; else next[i]=true;
      return next;
    });
  }
  /* ---- detect win locally, announce to room ---- */
  useEffect(()=>{
    if(!myCells) return;
    const arr = myCells.map((_,i)=> !!myMarks[i] || i===12);
    const ln = checkWin(arr);
    if(ln && !didWin){
      setDidWin(true); setWinLine(ln);
      announceBingo();
    }
    if(!ln && didWin){ setDidWin(false); setWinLine(null); }
  }, [myMarks, myCells]);
  async function announceBingo(){
    const data = await loadRoom(code);
    if(!data) return;
    if(data.players[meId] && !data.players[meId].bingoAt){
      data.players[meId].bingoAt = Date.now();
      const place = Object.values(data.players).filter(p=>p.bingoAt).length;
      data.feed = [{ t: now(), who: data.players[meId].name, msg: place===1 ? 'GOT BINGO FIRST 🏆' : got bingo (#${place}) }, ...(data.feed||[])].slice(0,40);
      await saveRoom(code, data);
      setRoom(data);
    }
  }
  async function leave(){
    clearInterval(pollRef.current);
    const data = await loadRoom(code);
    if(data && data.players[meId]){
      const nm = data.players[meId].name;
      delete data.players[meId];
      data.feed = [{ t: now(), who: nm, msg: 'left the meeting 🚪' }, ...(data.feed||[])].slice(0,40);
      await saveRoom(code, data);
    }
    setView('lobby'); setCode(null); setRoom(null); setMyCells(null); setMyMarks({}); setDidWin(false);
  }
  async function newCard(){
    if(!room) return;
    setMyCells(buildCard(room.phrases)); setMyMarks({12:true}); setDidWin(false); setWinLine(null);
    // also clear my bingoAt so a fresh card can win again
    const data = await loadRoom(code);
    if(data && data.players[meId]){ data.players[meId].bingoAt = null; await saveRoom(code, data); setRoom(data); }
    showToast('Fresh card dealt');
  }
  function openEditor(){
    if(!room) return;
    setEditText(room.phrases.join('\n'));
    setEditTitle(room.title);
    setEditErr('');
    setShowEdit(true);
  }
  async function saveNewBoard(){
    setEditErr('');
    const phrases = editText.split('\n').map(s=>s.trim().replace(/^["']|["']$/g,'')).filter(Boolean);
    if(phrases.length < 24){ setEditErr(Need at least 24 phrases — you have ${phrases.length}.); return; }
    const data = await loadRoom(code);
    if(!data){ setEditErr('Lost the room. Try rejoining.'); return; }
    data.phrases = phrases;
    data.title = editTitle.trim() || data.title;
    data.round = (data.round || 1) + 1;
    // reset everyone's bingo status for the new round
    Object.keys(data.players).forEach(id=>{ data.players[id].bingoAt = null; });
    data.feed = [{ t: now(), who: data.players[meId]?.name || 'Host', msg: revised the board — round ${data.round} 🔄 }, ...(data.feed||[])].slice(0,40);
    await saveRoom(code, data);
    setRoom(data);
    // re-deal my own card immediately
    seenRound.current = data.round;
    setMyCells(buildCard(phrases)); setMyMarks({12:true}); setDidWin(false); setWinLine(null);
    setShowEdit(false);
    showToast('New board sent to everyone');
  }
  function copyCode(){
    const t = code;
    if(navigator.clipboard){ navigator.clipboard.writeText(t).then(()=>showToast('Room code copied')); }
    else showToast('Code: '+t);
  }
  /* =================== RENDER =================== */
  if(view==='lobby'){
    return (
      <div className="wrap">
        <div className="memo-head">
          <div className="eyebrow">Interoffice Memo · Re: Morale</div>
          <h1 className="memo-title">Buzzword <em>Bingo</em></h1>
          <p className="memo-sub">A live game for the next all-hands, stand-up, or town hall. Make a card of the phrases your coworkers can't stop saying, share the room code, and quietly compete while looking very engaged.</p>
        </div>
        <div className="tabs">
          <div className={"tab"+(tab==='join'?' active':'')} onClick={()=>{setTab('join');setErr('')}}>Join a Room</div>
          <div className={"tab"+(tab==='host'?' active':'')} onClick={()=>{setTab('host');setErr('')}}>Host a Room</div>
        </div>
        <div className="panel">
          <label className="field">Your name (or alias)</label>
          <input className="text" placeholder="e.g. Definitely Working" value={name} onChange={e=>setName(e.target.value)} maxLength={24}/>
        </div>
        {tab==='join' ? (
          <div className="panel">
            <h2>Have a code?</h2>
